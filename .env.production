# ──────────────────────────────────────────────────────────────
# CES ERP backend — PRODUCTION (server) konfiqurasiyası
# Serverdə bu faylın məzmununu `.env` adı ilə yerləşdirin:
#   cp .env.production .env
# Spring yalnız `.env` faylını oxuyur — bu fayl referansdır.
# ──────────────────────────────────────────────────────────────

# Mobil tətbiqin və web client-lərin çağırdığı public API ünvanı
API_BASE_URL=http://api.ces.invorent.com

# CORS — icazəli origin-lər (mobil app / web client)
CORS_ALLOWED_ORIGINS=http://api.ces.invorent.com,https://api.ces.invorent.com,http://localhost:3000,http://localhost:5173

# Email linklərində istifadə olunan frontend ünvanı
APP_FRONTEND_URL=http://api.ces.invorent.com
