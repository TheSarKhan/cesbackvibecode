# ──────────────────────────────────────────────────────────────
# CES ERP backend — PRODUCTION (server) konfiqurasiyası
# Serverdə bu faylın məzmununu `.env` adı ilə yerləşdirin:
#   cp .env.production .env
# Spring yalnız `.env` faylını oxuyur — bu fayl referansdır.
# ──────────────────────────────────────────────────────────────

# Backend-in öz public ünvanı
API_BASE_URL=https://api.ces.invorent.com

# CORS — backend-ə sorğu göndərən FRONTEND/client origin-ləri (vergüllə).
# DİQQƏT: bura frontend-in açıldığı domen yazılır (api domeni DEYİL).
CORS_ALLOWED_ORIGINS=https://ces.invorent.com,https://www.ces.invorent.com,http://localhost:3000,http://localhost:5173

# Email linklərində istifadə olunan frontend ünvanı
APP_FRONTEND_URL=https://ces.invorent.com
