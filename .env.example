# ──────────────────────────────────────────────────────────────
# CES ERP backend — mühit konfiqurasiyası ŞABLONU
# Bu faylı `.env` adı ilə kopyalayın və dəyərləri öz mühitinizə uyğun doldurun.
#   cp .env.example .env
# `.env` faylı git-ə commit olunmur.
# ──────────────────────────────────────────────────────────────

# Mobil tətbiqin və web client-lərin çağırdığı public API ünvanı
API_BASE_URL=http://localhost:8083

# CORS — backend-ə sorğu göndərməyə icazəli origin-lər (vergüllə ayrılır)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email linklərində istifadə olunan frontend ünvanı
APP_FRONTEND_URL=http://localhost:3000
